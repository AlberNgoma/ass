<div class="card">
    <div class="card-image">
        <figure class="image">
            <img src="/files/img/users/{{user.photo}}" alt="{{user.name}}" />
        </figure>
    </div>
    <div class="card-content">
        <div class="media">
            <div class="media-content">
                <h3 class="has-text-weight-bold has-text-primary is-size-4">{{user.name}}</h3>
                <h4 class="has-text-weight-semibold is-size-6 mt-1">{{user.tel}}</h4>
            </div>
        </div>

        <div class="content">
            <span class="tag is-light has-text-drak is-size-6">{{user.role}}</span>
        </div>
    </div>
</div>